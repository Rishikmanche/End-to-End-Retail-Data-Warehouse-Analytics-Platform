# =============================================================================
# Retail Data Warehouse — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# =============================================================================

# ---- PostgreSQL Database ---------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_warehouse
DB_USER=retail_user
DB_PASSWORD=retail_pass_2024

# ---- Application -----------------------------------------------------------
LOG_LEVEL=INFO
DATA_DIR=./data
ENVIRONMENT=development

# ---- FastAPI ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---- Redis (used by Airflow / caching) -------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Airflow ---------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=change-me-to-a-real-fernet-key
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-to-a-real-secret-key

# ---- Docker Compose Postgres (used by compose env_file) --------------------
POSTGRES_DB=retail_warehouse
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_pass_2024
